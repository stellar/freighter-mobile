#!/usr/bin/env bash
# Setup Xcode 26.1 for CI environments
# Pinned to 26.1 due to iOS 26.3 breaking Maestro recordings

set -e

TARGET_VERSION="26.1"

echo "Looking for Xcode $TARGET_VERSION..."

# Find all Xcode installations
XCODE_PATHS=$(ls -1d /Applications/Xcode*.app 2>/dev/null || true)

if [ -z "$XCODE_PATHS" ]; then
  echo "Error: No Xcode installation found in /Applications"
  exit 1
fi

# Find Xcode 26.1.x
MATCHING_XCODE=""
MATCHING_VERSION=""

for XCODE_PATH in $XCODE_PATHS; do
  VERSION=$(/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" "$XCODE_PATH/Contents/Info.plist" 2>/dev/null || echo "0")
  if [ "$VERSION" != "0" ]; then
    # Check if version starts with 26.1
    if [[ "$VERSION" == ${TARGET_VERSION}* ]]; then
      echo "Found matching Xcode: $XCODE_PATH (Version: $VERSION)"
      MATCHING_XCODE="$XCODE_PATH"
      MATCHING_VERSION="$VERSION"
      break
    fi
  fi
done

if [ -z "$MATCHING_XCODE" ]; then
  echo "Error: Xcode $TARGET_VERSION not found"
  echo "Available Xcode versions:"
  for XCODE_PATH in $XCODE_PATHS; do
    VERSION=$(/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" "$XCODE_PATH/Contents/Info.plist" 2>/dev/null || echo "unknown")
    echo "  - $XCODE_PATH (Version: $VERSION)"
  done
  exit 1
fi

echo "Selected Xcode: $MATCHING_XCODE (Version: $MATCHING_VERSION)"
sudo xcode-select -s "$MATCHING_XCODE"
